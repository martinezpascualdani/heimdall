# =============================================================================
# Heimdall – environment variables example
# Copy to .env and adjust. Do not commit .env (it is in .gitignore).
# With Docker Compose, most of this is set in docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (local dev; Docker uses postgres:5432 and internal hostnames)
# Create databases: heimdall_datasets, heimdall_scope_service, heimdall_routing_service
# -----------------------------------------------------------------------------
# DATASET_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_datasets?sslmode=disable
# SCOPE_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_scope_service?sslmode=disable
# ROUTING_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_routing_service?sslmode=disable

# -----------------------------------------------------------------------------
# dataset-service
# -----------------------------------------------------------------------------
DATASET_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_datasets?sslmode=disable
DATASET_STORAGE_PATH=./data/datasets
PORT=8080

# -----------------------------------------------------------------------------
# scope-service (must reach dataset-service for imports and sync)
# -----------------------------------------------------------------------------
SCOPE_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_scope_service?sslmode=disable
DATASET_SERVICE_URL=http://localhost:8080
PORT=8081

# -----------------------------------------------------------------------------
# routing-service (observed routing state; imports CAIDA from dataset-service)
# -----------------------------------------------------------------------------
ROUTING_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_routing_service?sslmode=disable
DATASET_SERVICE_URL=http://localhost:8080
PORT=8082

# -----------------------------------------------------------------------------
# Heimdallctl (CLI) – optional; used when running heimdallctl against services
# -----------------------------------------------------------------------------
# HEIMDALL_DATASET_URL=http://localhost:8080
# HEIMDALL_SCOPE_URL=http://localhost:8081
# HEIMDALL_ROUTING_URL=http://localhost:8082
# HEIMDALL_TARGET_URL=http://localhost:8083
# HEIMDALL_CAMPAIGN_URL=http://localhost:8084
# HEIMDALL_TIMEOUT=30

# -----------------------------------------------------------------------------
# target-service (target definitions, rules, materialization to CIDR snapshots)
# -----------------------------------------------------------------------------
# TARGET_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_target_service?sslmode=disable
# SCOPE_SERVICE_URL=http://localhost:8081
# ROUTING_SERVICE_URL=http://localhost:8082
# PORT=8083

# -----------------------------------------------------------------------------
# campaign-service (control plane: campaigns, scan profiles, runs; dispatch to Redis)
# -----------------------------------------------------------------------------
# CAMPAIGN_DB_DSN=postgres://heimdall:heimdall@localhost:5432/heimdall_campaign_service?sslmode=disable
# REDIS_ADDR=localhost:6379
# TARGET_SERVICE_URL=http://localhost:8083
# PORT=8084
# CAMPAIGN_SCHEDULER_ENABLED=true

# -----------------------------------------------------------------------------
# Optional (defaults used if unset)
# -----------------------------------------------------------------------------
# Fetch timeouts are in code (e.g. 10m). Override via config if needed later.
