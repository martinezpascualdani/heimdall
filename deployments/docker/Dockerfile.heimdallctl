FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /heimdallctl ./cmd/heimdallctl

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /heimdallctl .
# ENTRYPOINT so that: docker run ... install => ./heimdallctl install
ENTRYPOINT ["./heimdallctl"]
CMD ["--help"]
